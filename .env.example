# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Your production URL — used for sitemap and OG metadata.
# Example: https://autobeets.vercel.app  or  https://yourdomain.com
SITE_URL=https://autobeets.vercel.app

# Server-side only — NOT exposed to the browser.
# URL of your n8n webhook that powers the chat widget.
# Example: https://your-n8n-instance.com/webhook/chat
N8N_WEBHOOK_URL=
